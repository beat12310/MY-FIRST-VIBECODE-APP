{
  "name": "aws-amplify-gen2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bash scripts/build-safe.sh",
    "start": "next start",
    "lint": "next lint",
    "deploy": "node scripts/one-click-deploy.mjs",
    "deploy:quick": "node scripts/one-click-deploy.mjs --skip-build",
    "rollback": "node scripts/one-click-deploy.mjs --rollback --skip-build",
    "deploy:status": "node scripts/one-click-deploy.mjs --status",
    "cognito:setup": "node scripts/cognito-setup.mjs",
    "cognito:add-google": "node scripts/cognito-setup.mjs --add-google",
    "cognito:add-apple": "node scripts/cognito-setup.mjs --add-apple",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check-deps": "tsx scripts/check-platform-deps.ts",
    "verify": "npm run typecheck && npm test && npm run check-deps",
    "verify:real-ai": "tsx scripts/real-ai-verification.ts",
    "verify:golden-suite": "tsx scripts/golden-project-suite.ts",
    "prepare": "husky || exit 0"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.5.5",
    "@aws-sdk/client-amplify": "^3.1075.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1057.0",
    "@aws-sdk/client-codecommit": "^3.1075.0",
    "@aws-sdk/client-dynamodb": "^3.1075.0",
    "@aws-sdk/client-iam": "^3.1075.0",
    "@aws-sdk/client-route-53": "^3.1075.0",
    "@aws-sdk/client-route-53-domains": "^3.1075.0",
    "@aws-sdk/lib-dynamodb": "^3.1075.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "archiver": "^8.0.0",
    "aws-amplify": "^6.6.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "gsap": "^3.15.0",
    "jose": "^6.2.3",
    "lottie-react": "^2.4.1",
    "lucide-react": "^1.21.0",
    "next": "14.2.10",
    "playwright": "^1.61.0",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.5.1",
    "@aws-amplify/backend-cli": "^1.3.0",
    "@aws-sdk/client-acm": "^3.1075.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1075.0",
    "@aws-sdk/client-sesv2": "^3.1075.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/archiver": "^8.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.5.2",
    "aws-cdk": "^2",
    "aws-cdk-lib": "^2",
    "constructs": "^10.3.0",
    "esbuild": "^0.23.1",
    "husky": "^9.1.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "vitest": "^4.1.9"
  }
}
