# ── AWS credentials ──────────────────────────────────────────────────────────
# Required for Bedrock (AI generation) and SES (email delivery).
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is listed in .gitignore.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Bedrock model routing ─────────────────────────────────────────────────────
# Each tier maps to a specific use-case. All values below are the verified
# working model IDs for account type matching this project (2026-06-22).
# If a variable is unset, lib/constants.ts uses the verified default.
#
# HAIKU    → simple chat, quick explanations, logo generation (fast + cheap)
# SONNET   → app generation, coding, debugging, repair loop  (best quality/speed)
# OPUS     → advanced repair, repeated failures, full rewrites (highest reasoning)
# STRONGEST → alias for OPUS — use whichever name feels clearer to you
#
# Resolution order (first non-empty value wins):
#   BEDROCK_MODEL_HAIKU     → BEDROCK_MODEL_ID → hardcoded default
#   BEDROCK_MODEL_SONNET    → hardcoded default
#   BEDROCK_MODEL_STRONGEST → BEDROCK_MODEL_OPUS → hardcoded default
#
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_HAIKU=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_SONNET=us.anthropic.claude-sonnet-4-6
BEDROCK_MODEL_OPUS=global.anthropic.claude-opus-4-6-v1
BEDROCK_MODEL_STRONGEST=global.anthropic.claude-opus-4-6-v1

# ── Email ─────────────────────────────────────────────────────────────────────
DWOMOH_SES_FROM_EMAIL=

# ── Cognito authentication ────────────────────────────────────────────────────
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_USER_POOL_ID=
NEXT_PUBLIC_USER_POOL_CLIENT_ID=

# ── RapidAPI (sports/weather integrations for generated apps) ─────────────────
RAPIDAPI_KEY=

# ── Payments (fill in when ready to take subscriptions) ──────────────────────
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=
NEXT_PUBLIC_PAYSTACK_STARTER_PLAN=
NEXT_PUBLIC_PAYSTACK_PRO_PLAN=
NEXT_PUBLIC_PAYSTACK_BUSINESS_PLAN=
